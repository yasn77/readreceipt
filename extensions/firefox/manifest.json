{
  "manifest_version": 2,
  "name": "Read Receipt",
  "version": "0.2.0",
  "description": "Enable read receipts for webmail services",
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Read Receipt",
    "default_icon": {
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "tabs",
    "storage",
    "activeTab",
    "https://mail.google.com/*",
    "https://outlook.live.com/*",
    "https://*.yahoo.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    "content.js"
  ],
  "applications": {
    "gecko": {
      "id": "readreceipt@example.com",
      "strict_min_version": "91.0"
    }
  }
}
