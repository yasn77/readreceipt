# Flask configuration
FLASK_ENV=development
FLASK_DEBUG=true
PORT=5000

# Database (future use - currently using in-memory store)
# DATABASE_URL=postgresql://user:password@localhost:5432/readreceipt

# Authentication (simple token for now, pluggable for JWT/SSO later)
ADMIN_TOKEN=change-me-in-production

# Extension configuration
EXTENSION_ALLOWED_ORIGINS=https://mail.google.com,https://outlook.live.com

# Logging
LOG_LEVEL=INFO

# Prometheus (optional)
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus
