# ReadReceipt Docker Environment Configuration
# Copy this file to .env and customize for your deployment

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=false
PORT=8000

# Security - CHANGE THIS IN PRODUCTION!
ADMIN_TOKEN=change-me-in-production
SECRET_KEY=your-secret-key-here

# Database
# For SQLite (default):
SQLALCHEMY_DATABASE_URI=sqlite:////app/data/readreceipt.db
# For PostgreSQL (recommended for production):
# SQLALCHEMY_DATABASE_URI=postgresql://readreceipt:changeme@postgres:5432/readreceipt

# Extension Configuration
EXTENSION_ALLOWED_ORIGINS=https://mail.google.com,https://outlook.live.com

# Logging
LOG_LEVEL=INFO

# OIDC Configuration (optional)
# OIDC_CLIENT_ID=your-client-id
# OIDC_CLIENT_SECRET=your-client-secret
# OIDC_DISCOVERY_URL=https://accounts.google.com/.well-known/openid-configuration
# OIDC_ALLOWED_EMAILS=admin@example.com
# OIDC_ADMIN_ROLES=admin,superuser

# Prometheus Metrics (optional)
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus
